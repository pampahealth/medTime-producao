{
  "name": "projeto-rotas-front",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo: FrontEnd (Next.js) + ProjetoRotas (API)",
  "scripts": {
    "dev": "npm run dev --prefix apps/FrontEnd",
    "dev:front": "npm run dev --prefix apps/FrontEnd",
    "dev:api": "npm run dev --prefix apps/ProjetoRotas",
    "install:all": "npm install --prefix apps/ProjetoRotas && npm install --legacy-peer-deps --prefix apps/FrontEnd",
    "build": "npm run build --prefix apps/FrontEnd"
  }
}
