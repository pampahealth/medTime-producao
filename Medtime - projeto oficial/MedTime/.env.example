# Template de ambiente consolidado do monorepo
# Copie somente as secoes necessarias para cada modulo:
# - MedTime/apps/FrontEnd/.env.local
# - MedTime/apps/ProjetoRotas/.env
# - testes/api_tripla_26.03/.env

############################################
# ProjetoRotas (MedTime/apps/ProjetoRotas)
############################################
PORT=3333
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=SEU_SUPABASE_ANON_KEY
JWT_SECRET=ALTERE_PARA_UM_SEGREDO_FORTE

############################################
# FrontEnd (MedTime/apps/FrontEnd)
############################################
POSTGREST_URL=https://SEU-POSTGREST.exemplo.com
POSTGREST_SCHEMA=SEU_SCHEMA
POSTGREST_API_KEY=SUA_CHAVE_POSTGREST
NEXT_PUBLIC_ENABLE_AUTH=true
SCHEMA_USER=SEU_SCHEMA_USER
SCHEMA_ADMIN_USER=SEU_SCHEMA_ADMIN
USE_BACKEND_PROXY=false
API_BACKEND_URL=http://localhost:3333
NEXT_PUBLIC_ZOER_HOST=https://zoer.cloud

############################################
# API Tripla (testes/api_tripla_26.03)
############################################
API_TRIPLA_PORT=3010
API_TRIPLA_SUPABASE_URL=https://SEU-PROJETO.supabase.co
API_TRIPLA_SUPABASE_KEY=SUA_CHAVE_SUPABASE
PYTHON_UI_CMD=python3 viewer_api_tripla.py
# Alternativa para abrir URL automaticamente:
# PYTHON_UI_URL=http://localhost:3010/health
