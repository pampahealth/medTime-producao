
# ============================================
# CONFIGURAÇÕES DO BANCO DE DADOS (OBRIGATÓRIO)
# ============================================
# URL do PostgREST (servidor de API do banco de dados)
POSTGREST_URL=https://seu-postgrest-url.com

# Schema do banco de dados
POSTGREST_SCHEMA=app20260109065139cnigtntalr_v1

# Chave de API do PostgREST
POSTGREST_API_KEY=sua-chave-api-aqui

# ============================================
# CONFIGURAÇÕES DE AUTENTICAÇÃO (OBRIGATÓRIO)
# ============================================
# Habilitar autenticação (true/false)
NEXT_PUBLIC_ENABLE_AUTH=true

# Secret para geração de tokens JWT (use uma string aleatória e segura)
JWT_SECRET=sua-chave-secreta-jwt-muito-segura-aqui

# Roles do banco de dados
SCHEMA_USER=app20260109065139cnigtntalr_v1_user
SCHEMA_ADMIN_USER=app20260109065139cnigtntalr_v1_admin_user

# ============================================
# PROXY PARA BACKEND (ProjetoRotas)
# ============================================
# Ativar proxy para usar a API do ProjetoRotas (true/false)
USE_BACKEND_PROXY=false

# URL do backend ProjetoRotas (quando USE_BACKEND_PROXY=true)
API_BACKEND_URL=http://localhost:3333

# ============================================
# CONFIGURAÇÕES OPCIONAIS
# ============================================
# Host público da aplicação Zoer (para envio de emails)
NEXT_PUBLIC_ZOER_HOST=https://zoer.cloud

# Chave do Resend (serviço de email) - opcional
# RESEND_KEY=re_sua_chave_resend_aqui
